{
  "name": "piperun",
  "version": "0.1.0",
  "description": "A locally executable pipeline framework inspired by Azure DevOps YAML pipelines",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "piperun": "dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:unit": "vitest run -c vitest.config.unit.ts",
    "test:integration": "vitest run -c vitest.config.integration.ts",
    "test:e2e": "vitest run -c vitest.config.e2e.ts",
    "test:watch": "vitest",
    "test:coverage": "npm run test:coverage:unit && npm run test:coverage:integration && npm run test:coverage:e2e",
    "test:coverage:unit": "vitest run -c vitest.config.unit.ts --coverage",
    "test:coverage:integration": "vitest run -c vitest.config.integration.ts --coverage",
    "test:coverage:e2e": "vitest run -c vitest.config.e2e.ts --coverage",
    "lint": "eslint src/ tests/",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js"
  },
  "keywords": [
    "pipeline",
    "ci",
    "cd",
    "yaml",
    "devops",
    "local",
    "runner"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "js-yaml": "^4.1.1",
    "ora": "^9.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.3.5",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
